{
  "expo": {
    "name": "Fanium Challenge",
    "slug": "fanium-challenge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "fanium-challenge",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B985D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fanium.challenge"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07192A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.fanium.challenge"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-image",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/VanguardCF-Bold.otf",
            "./assets/fonts/VanguardCF-ExtraBold.otf",
            "./assets/fonts/VanguardCF-Medium.otf",
            "./assets/fonts/VanguardCF-Regular.otf",
            "./assets/fonts/VanguardCF-DemiBold.otf",
            "./assets/fonts/VanguardCF-Heavy.otf",
            "./assets/fonts/VanguardCF-Light.otf",
            "./assets/fonts/VanguardCF-Thin.otf",
            "./assets/fonts/RobotoCondensed-Bold.ttf",
            "./assets/fonts/RobotoCondensed-Regular.ttf",
            "./assets/fonts/Arnold Sans.otf"
          ]
        }
      ],
      "expo-router"
    ]
  }
}
